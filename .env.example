# ===== ArrPulse — configuração =====
# Copie para .env e ajuste. Só APP_SECRET é obrigatório.

# Porta e host de escuta (dentro do container)
PORT=8080
HOST=0.0.0.0

# Caminho do banco SQLite (dentro do container; o volume monta ./data aqui)
DB_PATH=/app/data/arr-watch.db

# OBRIGATÓRIO — chave de criptografia das credenciais salvas no banco.
# Gere uma vez e NUNCA mude: use esse codigo no terminal: openssl rand -hex 32 
APP_SECRET=

# Intervalo de verificação de saúde, em segundos (mínimo 15)
POLL_INTERVAL=60

# Fuso horário (afeta quiet hours e digest). Ex.: America/Sao_Paulo
TZ=America/Cuiaba

# ---- Opcionais ----
# Login semeado por env (em vez de criar pela tela no 1º acesso)
# AUTH_USERNAME=admin
# AUTH_PASSWORD=troque-isto
# AUTH_RESET=1            # reseta o login no boot; remova depois de usar

# Idioma padrão da detecção de imports
# DEFAULT_LANGUAGE=pt

# Push ntfy (também configurável pela UI em Settings)
# NTFY_URL=https://ntfy.sh
# NTFY_TOPIC=meu-topico-secreto
# NTFY_TOKEN=
